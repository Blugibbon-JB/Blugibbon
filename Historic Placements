function uniq(arr){ return [...new Set(arr)].filter(Boolean).sort((a,b)=>a.localeCompare(b)); }
function fmtDate(s){ if(!s) return ''; const [y,m,d]=s.split('-'); const mo=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][+m-1]; return `${+d} ${mo} ${y}`; }
function statusClass(s){
  const k = (s||'').toLowerCase();
  if (k.includes('done') || k.includes('complete')) return 'status-done';
  if (k.includes('current') || k.includes('processing')) return 'status-current';
  if (k.includes('to do') || k.includes('pending')) return 'status-todo';
  if (k.includes('return')) return 'status-return';
  return 'status-other';
}
function esc(s){ return String(s==null?'':s).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function hl(s, q){
  if(!q) return esc(s);
  const i = s.toLowerCase().indexOf(q.toLowerCase());
  if (i<0) return esc(s);
  return esc(s.slice(0,i)) + '<mark>' + esc(s.slice(i, i+q.length)) + '</mark>' + esc(s.slice(i+q.length));
}

