document.getElementById('recruiterFilter').innerHTML = '<option value="">All recruiters</option>' + uniq(DATA.map(r=>r.rec)).map(s=>`<option>${esc(s)}</option>`).join('');
document.getElementById('statusFilter').innerHTML = '<option value="">All statuses</option>' + uniq(DATA.map(r=>r.st)).map(s=>`<option>${esc(s)}</option>`).join('');

const state = {
  q: '', year: '', site: '', rec: '', status: '', from: '', to: '',
  view: 'docs', openDoctors: new Set(), sortKey: 's', sortDir: 1,
  page: 1, pageSize: 100,
};

function applyFilters() {
  const q = state.q.trim().toLowerCase();
  return DATA.filter(r => {
    if (q) {
      const hay = (r.d + ' ' + r.site + ' ' + r.p + ' ' + r.tid).toLowerCase();
      if (!hay.includes(q)) return false;
    }
    if (state.year && r.y !== state.year) return false;
    if (state.site && r.site !== state.site) return false;
    if (state.rec && r.rec !== state.rec) return false;
    if (state.status && r.st !== state.status) return false;
    if (state.from && (!r.s || r.s < state.from)) return false;
    if (state.to && (!r.s || r.s > state.to)) return false;
    return true;
  });
}

function render() {
  const filtered = applyFilters();
  document.getElementById('countPlacements').textContent = filtered.length.toLocaleString();
  document.getElementById('countDoctors').textContent = new Set(filtered.map(r=>r.d)).size.toLocaleString();
  document.getElementById('countSites').textContent = new Set(filtered.map(r=>r.site).filter(Boolean)).size.toLocaleString();

  const emptyEl = document.getElementById('empty');
  const docsEl = document.getElementById('docsView');
  const flatEl = document.getElementById('flatView');

  if (filtered.length === 0) {
    emptyEl.style.display = 'block';
    docsEl.style.display = 'none';
    flatEl.style.display = 'none';
    return;
  }
  emptyEl.style.display = 'none';

  if (state.view === 'docs') {
    docsEl.style.display = 'block';
    flatEl.style.display = 'none';
    renderDocs(filtered);
  } else {
    docsEl.style.display = 'none';
    flatEl.style.display = 'block';
    renderFlat(filtered);
  }
}

function renderDocs(records) {
  const byDoc = new Map();
  for (const r of records) {
    if (!byDoc.has(r.d)) byDoc.set(r.d, []);
    byDoc.get(r.d).push(r);
  }
  const docs = [...byDoc.entries()].sort((a,b)=>a[0].localeCompare(b[0]));
  const q = state.q.trim();
  const html = docs.map(([name, recs]) => {
    recs.sort((a,b)=>(b.s||'').localeCompare(a.s||''));
    const dates = recs.map(r=>r.s).filter(Boolean).sort();
    const first = dates[0], last = dates[dates.length-1];
    const sites = uniq(recs.map(r=>r.site));
    const isOpen = state.openDoctors.has(name);
    return `
      <div class="doc-card${isOpen?' open':''}" data-doc="${esc(name)}">
        <div class="doc-header" data-toggle="${esc(name)}">
          <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          <div class="name">${hl(name, q)}</div>
          <span class="chip">${recs.length} placement${recs.length>1?'s':''}</span>
          <div class="doc-meta">
            <span>${sites.length} site${sites.length!==1?'s':''}</span>
            ${first?`<span>${fmtDate(first)} — ${fmtDate(last)}</span>`:''}
          </div>
        </div>
        <div class="doc-body">
          ${renderPlacementTable(recs, q)}
        </div>
      </div>`;
  }).join('');
  document.getElementById('docsView').innerHTML = html;
}

function renderPlacementTable(recs, q) {
  return `
    <table class="placement-table">
      <thead><tr>
        <th>Placement ID</th><th>Start</th><th>End</th><th>Site</th>
        <th>Year</th><th>Status</th><th>Recruiter</th>
        <th>Accom</th><th>Car</th><th>Flights</th><th>Pay $</th>
      </tr></thead>
      <tbody>
        ${recs.map(r=>`
          <tr>
            <td class="pid">${hl(r.p||'—', q)}</td>
            <td class="date">${fmtDate(r.s)}</td>
            <td class="date">${fmtDate(r.e)}</td>
            <td class="site-cell">${hl(r.site||'—', q)}</td>
            <td>${esc(r.y)}</td>
            <td><span class="chip ${statusClass(r.st)}">${esc(r.st||'—')}</span></td>
            <td>${esc(r.rec)}</td>
            <td>${esc(r.ac)}</td>
            <td>${esc(r.ca)}</td>
            <td>${esc(r.fl)}</td>
            <td>${r.pay!=null ? r.pay.toLocaleString() : ''}</td>
          </tr>`).join('')}
      </tbody>
    </table>`;
}

function renderFlat(records) {
  records = [...records].sort((a,b)=>{
    const k = state.sortKey, dir = state.sortDir;
    let va = a[k]||'', vb = b[k]||'';
    if (k === 'pay') { va = a.pay||0; vb = b.pay||0; }
    return (va < vb ? -1 : va > vb ? 1 : 0) * dir;
  });
  const total = records.length;
  const totalPages = Math.max(1, Math.ceil(total / state.pageSize));
  if (state.page > totalPages) state.page = totalPages;
  const start = (state.page-1) * state.pageSize;
  const pageRecords = records.slice(start, start + state.pageSize);
  const q = state.q.trim();

  const cols = [
    ['d', 'Doctor'], ['p', 'Placement ID'], ['s', 'Start'], ['e', 'End'],
    ['site', 'Site'], ['y', 'Year'], ['st', 'Status'], ['rec', 'Recruiter'],
    ['ac','Accom'], ['ca','Car'], ['fl','Flights'], ['pay','Pay $']
  ];
  const header = cols.map(([k,l])=>`<th data-sort="${k}" class="${state.sortKey===k?'sorted':''}">${l}<span class="sort-ind">${state.sortKey===k?(state.sortDir>0?'▲':'▼'):'⇅'}</span></th>`).join('');
  const rows = pageRecords.map(r=>`
    <tr>
      <td style="font-weight:500;">${hl(r.d, q)}</td>
      <td class="pid">${hl(r.p||'—', q)}</td>
      <td class="date">${fmtDate(r.s)}</td>
      <td class="date">${fmtDate(r.e)}</td>
      <td>${hl(r.site||'—', q)}</td>
      <td>${esc(r.y)}</td>
      <td><span class="chip ${statusClass(r.st)}">${esc(r.st||'—')}</span></td>
      <td>${esc(r.rec)}</td>
      <td>${esc(r.ac)}</td>
      <td>${esc(r.ca)}</td>
      <td>${esc(r.fl)}</td>
      <td>${r.pay!=null ? r.pay.toLocaleString() : ''}</td>
    </tr>`).join('');
  document.getElementById('flatView').innerHTML = `
    <div class="flat-wrap">
      <table class="placement-table">
        <thead><tr>${header}</tr></thead>
        <tbody>${rows}</tbody>
      </table>
      <div class="pager">
        <span>Showing ${start+1}–${Math.min(start+state.pageSize, total)} of ${total.toLocaleString()}</span>
        <div class="controls">
          <button id="prevPage" ${state.page<=1?'disabled':''}>← Prev</button>
          <span style="margin:0 8px;">Page ${state.page} / ${totalPages}</span>
          <button id="nextPage" ${state.page>=totalPages?'disabled':''}>Next →</button>
        </div>
      </div>
    </div>`;
  // wire sort + pager
  document.querySelectorAll('#flatView th[data-sort]').forEach(th=>{
    th.addEventListener('click', ()=>{
      const k = th.dataset.sort;
      if (state.sortKey === k) state.sortDir *= -1; else { state.sortKey = k; state.sortDir = 1; }
      state.page = 1; render();
    });
  });
  const prev = document.getElementById('prevPage'); if (prev) prev.onclick = ()=>{ state.page--; render(); window.scrollTo({top:0,behavior:'smooth'}); };
  const next = document.getElementById('nextPage'); if (next) next.onclick = ()=>{ state.page++; render(); window.scrollTo({top:0,behavior:'smooth'}); };
}

// Wire up controls
const debounce = (fn, ms) => { let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a), ms); }; };
document.getElementById('searchInput').addEventListener('input', debounce(e=>{ state.q = e.target.value; state.page=1; render(); }, 120));
document.getElementById('yearFilter').addEventListener('change', e=>{ state.year = e.target.value; state.page=1; render(); });
document.getElementById('siteFilter').addEventListener('change', e=>{ state.site = e.target.value; state.page=1; render(); });
document.getElementById('recruiterFilter').addEventListener('change', e=>{ state.rec = e.target.value; state.page=1; render(); });
document.getElementById('statusFilter').addEventListener('change', e=>{ state.status = e.target.value; state.page=1; render(); });
document.getElementById('dateFrom').addEventListener('change', e=>{ state.from = e.target.value; state.page=1; render(); });
document.getElementById('dateTo').addEventListener('change', e=>{ state.to = e.target.value; state.page=1; render(); });
document.getElementById('viewDocs').addEventListener('click', ()=>{ state.view='docs'; document.getElementById('viewDocs').classList.add('active'); document.getElementById('viewFlat').classList.remove('active'); render(); });
document.getElementById('viewFlat').addEventListener('click', ()=>{ state.view='flat'; document.getElementById('viewFlat').classList.add('active'); document.getElementById('viewDocs').classList.remove('active'); render(); });
document.getElementById('clearBtn').addEventListener('click', ()=>{
  state.q=''; state.year=''; state.site=''; state.rec=''; state.status=''; state.from=''; state.to=''; state.page=1; state.openDoctors.clear();
  document.getElementById('searchInput').value='';
  ['yearFilter','siteFilter','recruiterFilter','statusFilter','dateFrom','dateTo'].forEach(id=>document.getElementById(id).value='');
  render();
});
document.getElementById('expandAllBtn').addEventListener('click', ()=>{
  const filtered = applyFilters();
  const docs = new Set(filtered.map(r=>r.d));
  // If any closed, open all; otherwise close all
  const anyClosed = [...docs].some(d=>!state.openDoctors.has(d));
  if (anyClosed) state.openDoctors = new Set(docs);
  else state.openDoctors.clear();
  document.getElementById('expandAllBtn').textContent = anyClosed ? 'Collapse all' : 'Expand all';
  render();
});
// Toggle doctor cards (event delegation)
document.getElementById('docsView').addEventListener('click', e=>{
  const h = e.target.closest('.doc-header'); if (!h) return;
  const name = h.dataset.toggle;
  if (state.openDoctors.has(name)) state.openDoctors.delete(name);
  else state.openDoctors.add(name);
  render();
});
// CSV export of current filtered set
document.getElementById('exportBtn').addEventListener('click', ()=>{
  const rows = applyFilters();
  const cols = [['d','Doctor'],['p','Placement ID'],['s','Start'],['e','End'],['site','Site'],['sid','Site ID'],['y','Year'],['st','Status'],['rec','Recruiter'],['ass','Assignee'],['ac','Accom'],['ca','Car'],['fl','Flights'],['tr','Travel Reimb'],['pay','Pay Ex Super'],['tid','Task ID']];
  const esc = v => { v = v==null?'':String(v); return /[,"\n]/.test(v) ? '"'+v.replace(/"/g,'""')+'"' : v; };
  const csv = [cols.map(c=>esc(c[1])).join(','), ...rows.map(r=>cols.map(c=>esc(r[c[0]])).join(','))].join('\n');
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `blugibbon_placements_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
});

render();
</script>
</body>
</html>
